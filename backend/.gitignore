# Maven
# ══════════════════════════════════════════════════════
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ══════════════════════════════════════════════════════
# IDE
# ══════════════════════════════════════════════════════
.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.factorypath
*.swp
*~

# ══════════════════════════════════════════════════════
# OS
# ══════════════════════════════════════════════════════
.DS_Store
Thumbs.db

# ══════════════════════════════════════════════════════
# Environment & Secrets
# ══════════════════════════════════════════════════════
.env
*.log
hs_err_pid*
replay_pid*

