# URL base da API — em dev, deixe vazio para usar o Vite proxy.
# Em produção, aponte para o backend real (ex.: https://api.mangareader.com).
VITE_API_BASE_URL=

# Path base de roteamento/deploy. GitHub Pages usa "/Manga-Reader".
# Em outro ambiente use "/" ou o sub-path desejado.
VITE_BASE_URL=/Manga-Reader
